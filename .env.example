PORT=3001
# Comma-separated: user portal (:5173) + admin portal (:5174)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Supabase → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# MUST be the service_role secret key (NOT publishable / anon)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Anon / publishable key — used only server-side for login, refresh, and password reset
SUPABASE_ANON_KEY=your-anon-key

# HttpOnly refresh-token cookie — local dev only
COOKIE_NAME=vj_refresh_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Production: see .env.production.example (Render Web Service)
